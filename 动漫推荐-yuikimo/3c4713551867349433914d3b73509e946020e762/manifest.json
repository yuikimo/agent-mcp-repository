{
  "manifest_version": "0.3",
  "name": "ani-mcp",
  "version": "0.15.4",
  "display_name": "AniList MCP",
  "description": "A smart MCP server for AniList that gets your anime/manga taste - not just API calls.",
  "author": {
    "name": "gavxm"
  },
  "license": "MIT",
  "icon": "assets/icon.png",
  "keywords": [
    "anime",
    "manga",
    "anilist",
    "recommendations"
  ],
  "privacy_policies": [
    "https://github.com/gavxm/ani-mcp/blob/main/PRIVACY.md"
  ],
  "server": {
    "type": "node",
    "entry_point": "dist/index.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/dist/index.js"
      ],
      "env": {
        "ANILIST_USERNAME": "${user_config.anilist_username}",
        "ANILIST_TOKEN": "${user_config.anilist_token}"
      }
    }
  },
  "user_config": {
    "anilist_username": {
      "type": "string",
      "title": "AniList Username",
      "description": "Optional. Your AniList username so tools don't need to ask each time.",
      "required": false
    },
    "anilist_token": {
      "type": "string",
      "title": "AniList Token",
      "description": "Optional. Your AniList API token for write features (rate, update progress, etc.).",
      "required": false,
      "sensitive": true
    }
  },
  "tools": [
    {
      "name": "anilist_search"
    },
    {
      "name": "anilist_details"
    },
    {
      "name": "anilist_seasonal"
    },
    {
      "name": "anilist_recommendations"
    },
    {
      "name": "anilist_list"
    },
    {
      "name": "anilist_stats"
    },
    {
      "name": "anilist_trending"
    },
    {
      "name": "anilist_genres"
    },
    {
      "name": "anilist_genre_list"
    },
    {
      "name": "anilist_taste"
    },
    {
