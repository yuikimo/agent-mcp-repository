ANILIST_USERNAME="<your_username>"
ANILIST_TOKEN="<your_oauth_token>"  # Optional - only for write operations and private lists

# ANILIST_TITLE_LANGUAGE="english"  # Title preference: english (default), romaji, native
# ANILIST_SCORE_FORMAT="POINT_10"   # Override score format: POINT_100, POINT_10_DECIMAL, POINT_10, POINT_5, POINT_3
# ANILIST_NSFW="false"              # Show adult content in results (default: false)
# ANILIST_MOOD_CONFIG='{"mykeyword":{"boost":["Romance"],"penalize":["Horror"]}}'  # Custom mood keywords

# DEBUG="false"                     # Debug logging to stderr

# MCP_TRANSPORT="http"  # HTTP Stream transport (default: stdio)
# MCP_PORT="3000"
# MCP_HOST="0.0.0.0"